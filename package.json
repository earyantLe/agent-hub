{
  "name": "agent-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Make the web agent-ready",
  "scripts": {
    "dev": "pnpm --filter registry dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint -- --fix",
    "typecheck": "pnpm -r typecheck",
    "clean": "bash scripts/dev.sh clean",
    "db:start": "bash scripts/docker-db.sh",
    "db:stop": "docker stop agent-hub-db 2>/dev/null || true"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^7.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
